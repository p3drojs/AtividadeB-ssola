generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model receitas {
  id              Int            @id @default(autoincrement())
  nome            String
  tempoPreparo    Int
  custoAproximado Float
  ingredientes    Ingredientes[]
}

model Ingredientes {
  id        Int      @id @default(autoincrement())
  nome      String
  receitaId Int
  author    receitas @relation(fields: [receitaId], references: [id])
}
